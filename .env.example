# PostgreSQL connection strings
DATABASE_URL=postgresql+asyncpg://prism:prism@localhost:5432/prism
DATABASE_URL_SYNC=postgresql+psycopg2://prism:prism@localhost:5432/prism

# Anthropic API key — required for LLM extraction
ANTHROPIC_API_KEY=sk-ant-...

# Embedding model (sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# LLM model
LLM_MODEL=claude-sonnet-4-20250514

# CORS: comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:5173","https://puneethkotha.github.io"]
